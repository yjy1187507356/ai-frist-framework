{
  "name": "@scaffold/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "import": "./dist/client/index.ts",
      "types": "./dist/client/index.ts"
    }
  },
  "scripts": {
    "dev": "concurrently -n codegen,server -c blue,green \"pnpm codegen:watch\" \"node --import @swc-node/register/esm-register --watch src/server.ts\"",
    "dev:server": "node --import @swc-node/register/esm-register --watch src/server.ts",
    "codegen:watch": "node --import tsx scripts/codegen.ts --watch",
    "init-db": "node --import @swc-node/register/esm-register src/scripts/init-db.ts",
    "codegen": "node --import tsx scripts/codegen.ts",
    "build": "pnpm codegen && tsup",
    "start": "node dist/server.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ai-partner-x/aiko-boot-codegen": "workspace:*",
    "@ai-partner-x/aiko-boot": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-web": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-orm": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-validation": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-storage": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-mq": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "sql.js": "^1.11.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
