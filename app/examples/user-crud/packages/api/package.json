{
  "name": "@user-crud/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "import": "./dist/client/index.ts",
      "types": "./dist/client/index.ts"
    }
  },
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --watch src/server.ts",
    "init-db": "node --import @swc-node/register/esm-register src/scripts/init-db.ts",
    "codegen": "node --import tsx scripts/codegen.ts",
    "java": "npx aiko-codegen transpile src -p com.example.usercrud",
    "build": "pnpm codegen && tsup",
    "start": "node dist/server.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "@ai-partner-x/aiko-boot-codegen": "workspace:*",
    "@ai-partner-x/aiko-boot": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-web": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-orm": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-validation": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@swc/register": "^0.1.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
