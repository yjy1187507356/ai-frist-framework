{
  "name": "@app/cache-crud",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.11.0"
  },
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --watch src/index.ts",
    "start": "node --import @swc-node/register/esm-register src/index.ts",
    "server": "node --import @swc-node/register/esm-register src/server.ts",
    "server:dev": "node --import @swc-node/register/esm-register --watch src/server.ts",
    "init-db": "node --import @swc-node/register/esm-register src/scripts/init-db.ts",
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-partner-x/aiko-boot-starter-cache": "workspace:*",
    "@ai-partner-x/aiko-boot": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-orm": "workspace:*",
    "@ai-partner-x/aiko-boot-starter-web": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
