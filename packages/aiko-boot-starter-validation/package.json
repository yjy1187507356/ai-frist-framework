{
  "name": "@ai-partner-x/aiko-boot-starter-validation",
  "version": "0.1.0",
  "description": "Aiko Boot - Validation Starter with class-validator compatible decorators",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "aiko-boot.config.json"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-partner-x/aiko-boot": "workspace:*",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react-hook-form": ">=7.0.0",
    "@hookform/resolvers": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react-hook-form": { "optional": true },
    "@hookform/resolvers": { "optional": true }
  },
  "keywords": ["aiko-boot", "boot-starter-validation", "validation", "class-validator", "decorator", "typescript"]
}
