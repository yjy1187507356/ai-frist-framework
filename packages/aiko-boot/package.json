{
  "name": "@ai-partner-x/aiko-boot",
  "version": "0.1.0",
  "description": "Aiko Boot - Core Boot with DI, Configuration, and Auto-Configuration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./boot": {
      "import": "./dist/boot/index.js",
      "types": "./dist/boot/index.d.ts"
    },
    "./di": {
      "import": "./dist/di/index.js",
      "types": "./dist/di/index.d.ts"
    },
    "./di/server": {
      "import": "./dist/di/server.js",
      "types": "./dist/di/server.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "tsyringe": "^4.8.0",
    "reflect-metadata": "^0.2.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "aiko-boot",
    "spring-boot",
    "boot-starter",
    "dependency-injection",
    "auto-configuration",
    "decorator",
    "typescript"
  ]
}
