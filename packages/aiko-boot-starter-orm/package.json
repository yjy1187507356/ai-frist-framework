{
  "name": "@ai-partner-x/aiko-boot-starter-orm",
  "version": "0.1.0",
  "description": "Aiko Boot - ORM Starter with MyBatis-Plus compatible decorators",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "aiko-boot.config.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-partner-x/aiko-boot": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "kysely": "^0.28.11",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.11.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "mysql2": ">=2.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "keywords": [
    "aiko-boot",
    "boot-starter-orm",
    "orm",
    "mybatis-plus",
    "postgres",
    "decorator",
    "typescript"
  ]
}
