{
  "name": "@ai-partner-x/eslint-plugin-aiko-boot",
  "version": "0.1.0",
  "description": "ESLint plugin to enforce Java-compatible TypeScript code for Aiko Boot",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "java-compatible",
    "typescript",
    "aiko-boot"
  ],
  "peerDependencies": {
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^6.21.0",
    "@typescript-eslint/utils": "^6.21.0",
    "@types/eslint": "^8.56.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^6.21.0"
  }
}
