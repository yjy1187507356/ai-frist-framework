{
  "name": "aiko-boot",
  "version": "0.1.0",
  "private": true,
  "description": "aiko-boot Full-Stack Framework - Build with AI, Run Anywhere",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "create": "node packages/aiko-boot-create/dist/cli.js",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "eslint 'packages/**/*.{ts,tsx}'",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "rebuild:sqlite": "cd node_modules/.pnpm/better-sqlite3@12.6.2/node_modules/better-sqlite3 && npm run build-release"
  },
  "devDependencies": {
    "@ai-partner-x/eslint-plugin-aiko-boot": "workspace:*",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "packageManager": "pnpm@10.27.0"
}
